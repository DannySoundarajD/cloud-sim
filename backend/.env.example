# CloudSim Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:1@localhost:5432/cloudsim

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# Option 1: Use AWS credentials directly (not recommended for production)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI...

# Option 2: Use AWS profile (recommended)
# AWS_PROFILE=default

# AWS Region
AWS_REGION=us-east-1

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Set to 'production' in production environment
ENVIRONMENT=development

# Enable/disable Cost Explorer API (costs $0.01 per call)
ENABLE_COST_EXPLORER=true

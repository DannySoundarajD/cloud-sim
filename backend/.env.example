# CloudSim Backend Environment Configuration

# =============================================================================
# ENVIRONMENT
# =============================================================================
# Options: development, staging, production
ENVIRONMENT=development

# Enable debug mode (disable in production)
DEBUG=true

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://postgres:1@localhost:5432/cloudsim

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# IMPORTANT: Generate a secure key with: openssl rand -hex 32
# In production, this MUST be at least 32 characters!
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CORS & SECURITY
# =============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# AWS_PROFILE=default

# AWS Region and Account
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=096615316348

# =============================================================================
# IAM ROLE-BASED ACCESS (Optional)
# =============================================================================
# Enable role-based AWS access (users get different AWS permissions based on role)
ENABLE_ROLE_BASED_ACCESS=false

# IAM Role ARNs - uncomment and configure these if ENABLE_ROLE_BASED_ACCESS=true
# These roles must be created in AWS IAM with appropriate policies
# See backend/iam_setup.md for policy documentation

# AWS_ROLE_ADMIN=arn:aws:iam::096615316348:role/CloudSimAdminRole
# AWS_ROLE_DEVELOPER=arn:aws:iam::096615316348:role/CloudSimDeveloperRole
# AWS_ROLE_READONLY=arn:aws:iam::096615316348:role/CloudSimReadOnlyRole
# AWS_ROLE_STUDENT=arn:aws:iam::096615316348:role/CloudSimStudentRole

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Enable/disable Cost Explorer API (costs $0.01 per call)
ENABLE_COST_EXPLORER=true
